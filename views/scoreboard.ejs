<!DOCTYPE html>
<html>
<head>
<title>Scoreboard</title>
<link rel="stylesheet" href="/css/style.css">
</head>

<body>

<div class="navbar">

<h2>⚡ VIVY CTF</h2>

<div>
<a href="/challenge">Challenges</a>
<a href="/scoreboard">Scoreboard</a>
<a href="/profile">Profile</a>
</div>

</div>

<div class="container">

<h1 class="title">🏆 Team Scoreboard</h1>

<div class="card">

<table class="score-table">

<tr>
<th>#</th>
<th>Team</th>
<th>Score</th>
</tr>

<% if(teams.length === 0){ %>
<tr>
<td colspan="3" style="text-align:center;">Belum ada team</td>
</tr>
<% } %>

<% teams.forEach((t,i)=>{ %>

<tr>

<td>
<% if(i==0){ %> 🥇
<% } else if(i==1){ %> 🥈
<% } else if(i==2){ %> 🥉
<% } else { %>
<%= i+1 %>
<% } %>
</td>

<td><%= t.team_name %></td>

<td><%= t.score %></td>

</tr>

<% }) %>

</table>

</div>

</div>

</body>
</html>
