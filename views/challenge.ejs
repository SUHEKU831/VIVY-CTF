<!DOCTYPE html>
<html>
<head>
<title>Challenges</title>
<link rel="stylesheet" href="/css/style.css">
</head>

<body>

<div class="navbar">

<h2>⚡ VIVY CTF</h2>

<div>
<a href="/challenge">Challenges</a>
<a href="/scoreboard">Scoreboard</a>
<a href="/profile">Profile</a>
</div>

</div>

<div class="container">

<h1 class="title">Challenges</h1>

<% if(message){ %>
<div class="alert <%= type %>">
<%= message %>
</div>
<% } %>

<!-- 🔥 GROUP BY CATEGORY -->
<%
let grouped = {}
challs.forEach(c=>{
    if(!grouped[c.category]) grouped[c.category] = []
    grouped[c.category].push(c)
})
%>

<% for(let cat in grouped){ %>

<h2 style="margin-top:30px;"><%= cat %></h2>

<% grouped[cat].forEach(c=>{ %>

<div class="card">

<div class="card-header">
<h3><%= c.title %></h3>
<span class="points"><%= c.points %> pts</span>
</div>

<!-- 🔥 DESKRIPSI SUPPORT HTML -->
<p class="desc"><%- c.description %></p>

<!-- 🔥 FILE DOWNLOAD -->
<% if(c.file){ %>
<a href="/files/<%= c.file %>" class="download-btn">
Download File
</a>
<% } %>

<!-- 🔥 LINK SOAL -->
<% if(c.link){ %>
<br>
<a href="<%= c.link %>" target="_blank" class="download-btn">
Open Link
</a>
<% } %>

<form method="POST" action="/challenge/submit" class="flag-form">

<input type="hidden" name="id" value="<%= c.id %>">

<input name="flag" placeholder="Enter flag..." class="flag-input">

<button class="submit-btn">Submit</button>

</form>

</div>

<% }) %>

<% } %>

</div>

<script>
setTimeout(function(){
  const alert = document.querySelector('.alert');
  if(alert){
    alert.style.transition = "opacity 0.5s";
    alert.style.opacity = "0";
    setTimeout(()=> alert.remove(), 500);
  }
},3000);
</script>

</body>
</html>
