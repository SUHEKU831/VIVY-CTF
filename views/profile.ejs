<!DOCTYPE html>
<html>

<head>
<title>Profile</title>
<link rel="stylesheet" href="/css/style.css">
</head>

<body>

<div class="navbar">

<h2>⚡ VIVY CTF</h2>

<div>
<a href="/challenge">Challenges</a>
<a href="/scoreboard">Scoreboard</a>
<a href="/profile">Profile</a>
</div>

</div>

<div class="container">

<h1>Profile</h1>

<h3>Username: <%= user.username %></h3>

<h3>Score: <%= user.score %></h3>

<!-- ✅ TAMBAHAN TEAM -->
<h2>Team</h2>

<!-- (opsional tampilkan nama team) -->
<h3>Team Saat Ini: <%= user.team_name || "Belum punya team" %></h3>

<form method="POST" action="/profile/join-team">
    <input name="team" placeholder="Nama Team" required>
    <button>Join / Create Team</button>
</form>

<br>

<h2>Solved Challenges</h2>

<table class="score-table">

<tr>
<th>Challenge</th>
<th>Points</th>
</tr>

<% solves.forEach(s=>{ %>

<tr>
<td><%= s.title %></td>
<td><%= s.points %></td>
</tr>

<% }) %>

</table>

</div>

</body>
</html>
